<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi App</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 font-sans">


    <div class="flex min-h-screen">


        <aside class="w-64 bg-violet-800 text-white flex flex-col">

   
            <div class="px-6 py-5 border-b border-violet-700">
                <h1 class="text-xl font-bold tracking-wide"> animeflv event</h1>
            </div>
            


            <div style="margin-top: 40px" class="px-6 py-4 border-t border-violet-700 text-sm text-violet-200 ">
                otaku progress...
            </div>

        </aside>


        <div class="flex-1 flex flex-col">

   
            <header class="bg-white shadow px-8 py-4 flex items-center justify-between">

                <h2 class="text-lg font-semibold text-gray-700">
                    @ViewData["Title"]
                </h2>

                

            </header>

  
            <main class="flex-1 p-8">

         
                @if (TempData["Exito"] != null)
                {
                    <div class="mb-4 bg-green-100 text-green-800 border border-green-300 rounded-lg px-4 py-3">
                        ✅ @TempData["Exito"]
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="mb-4 bg-red-100 text-red-800 border border-red-300 rounded-lg px-4 py-3">
                        ❌ @TempData["Error"]
                    </div>
                }


                @RenderBody()

            </main>

        </div></div>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
