@model IEnumerable<riwiwi.Models.dashboard>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="bg-white rounded-xl shadow">

    <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 class="text-base font-semibold text-gray-700">Últimos Eventos</h3>
        <a asp-controller="dashboard" asp-action="newferia"
           class="bg-violet-700 hover:bg-violet-800 text-white text-sm px-4 py-2 rounded-lg transition">
            + Nuevo
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">

            <thead class="bg-gray-50 text-gray-500 uppercase text-xs">
                <tr>
                    <th class="px-6 py-3">Nombre</th>
                    <th class="px-6 py-3">Fecha</th>
                    <th class="px-6 py-3">Ubicación</th>
                    <th class="px-6 py-3">Estado</th>
                    <th class="px-6 py-3">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 font-medium text-gray-800">@item.Name</td>
                        <td class="px-6 py-4 text-gray-600">@item.Date.ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4 text-gray-600">@item.Location</td>
                        <td class="px-6 py-4">
                            <span class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">
                                @item.Status
                            </span>
                        </td>
                        <td class="px-6 py-4 flex gap-3">
                            <a asp-controller="dashboard" asp-action="Edit" asp-route-id="@item.Id"
                               class="text-violet-600 hover:underline">Editar</a>
                            <a asp-controller="dashboard" asp-action="Delete" asp-route-id="@item.Id"
                               class="text-red-500 hover:underline">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="px-6 py-4 border-t border-gray-200 text-xs text-gray-400"></div>

</div>