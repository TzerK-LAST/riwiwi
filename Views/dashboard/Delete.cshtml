@model riwiwi.Models.dashboard

@{
    ViewData["Title"] = "Eliminar Evento";
}

<div class="min-h-screen bg-gray-50 py-10 px-4">
    <div class="max-w-lg mx-auto">

        <div class="bg-white rounded-xl shadow overflow-hidden">

            <div class="px-6 py-5 border-b border-gray-200">
                <h3 class="text-base font-semibold text-gray-700">Confirmar eliminación</h3>
                <p class="text-sm text-gray-400 mt-1">Esta acción no se puede deshacer</p>
            </div>

            <div class="px-6 py-5 space-y-3">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Nombre</span>
                    <span class="text-gray-800 font-medium">@Model.Name</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Fecha</span>
                    <span class="text-gray-800">@Model.Date.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Ubicación</span>
                    <span class="text-gray-800">@Model.Location</span>
                </div>
                <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Estado</span>
                    <span class="bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">@Model.Status</span>
                </div>
            </div>

            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-end gap-3">
                <a asp-action="Index"
                   class="text-sm text-gray-500 hover:text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-200 transition">
                    Cancelar
                </a>
                <form asp-action="Destroy" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit"
                            class="bg-red-500 hover:bg-red-600 text-white text-sm font-medium px-6 py-2.5 rounded-lg transition">
                        Eliminar
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>